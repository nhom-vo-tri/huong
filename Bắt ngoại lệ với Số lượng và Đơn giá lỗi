TEST_CASE("4. Test Invalid Quantity and Price Exceptions", "[exception]") {
    CartService cartService;

    // TC6: Lỗi khi số lượng bằng 0
    REQUIRE_THROWS_AS(cartService.calculateTotal(100.0, 0, 10), std::invalid_argument);
    
    // TC7: Lỗi khi số lượng bị âm (-5)
    REQUIRE_THROWS_AS(cartService.calculateTotal(100.0, -5, 10), std::invalid_argument);
    
    // TC8: Lỗi khi đơn giá bị âm (-50)
    REQUIRE_THROWS_AS(cartService.calculateTotal(-50.0, 2, 0), std::invalid_argument);
}

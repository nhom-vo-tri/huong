TEST_CASE("5. Test Invalid Discount and Combined Exceptions", "[exception_all]") {
    CartService cartService;

    // TC9: Lỗi khi mức giảm giá bị âm (-5%)
    REQUIRE_THROWS_AS(cartService.calculateTotal(100.0, 2, -5), std::invalid_argument);
    
    // TC10: Lỗi khi mức giảm giá vượt khung cho phép (105%)
    REQUIRE_THROWS_AS(cartService.calculateTotal(100.0, 2, 105), std::invalid_argument);
    
    // TC19: Lỗi kết hợp đồng thời cả đơn giá âm và số lượng âm
    REQUIRE_THROWS_AS(cartService.calculateTotal(-10.0, -2, 10), std::invalid_argument);
    
    // TC20: Lỗi kết hợp khi mức giảm giá vượt quá xa (200%)
    REQUIRE_THROWS_AS(cartService.calculateTotal(10.0, 5, 200), std::invalid_argument);
}
